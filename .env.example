# DevFolio Configuration
# Copy this file to .env.local for local development

# Development Mode
# Controls whether the app runs in development mode (with full features) or production mode
# Options: true, false
# Default: false
DEV_MODE=false

# Theme Switching
# Enables theme switching in production mode
# Options: true, false
# Default: false
SWITCH_THEME=false

# Site URL
# The base URL of your deployed site (used for SEO metadata and structured data)
# Example: https://devfolio.charlyautomatiza.com
# Update this to your actual deployment URL
NEXT_PUBLIC_SITE_URL=https://devfolio.charlyautomatiza.com

# Google Sheets Integration (Optional)
# If you want to use Google Sheets for contact form submissions
# GOOGLE_PRIVATE_KEY=your-private-key-here
# GOOGLE_CLIENT_EMAIL=your-client-email-here
# GOOGLE_SHEET_ID=your-sheet-id-here
