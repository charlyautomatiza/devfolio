# DevFolio Environment Configuration
# Copy this file to .env.local for local development
# All site content and styling is configured in Markdown files (src/content/)
# These environment variables control advanced features only

# ============================================
# DEPLOYMENT SETTINGS
# ============================================

# Your Site URL (Required for SEO)
# Update this to match your deployment URL
# Example: https://your-portfolio.vercel.app
NEXT_PUBLIC_SITE_URL=https://devfolio.charlyautomatiza.com

# ============================================
# THEME & FEATURE SETTINGS
# ============================================

# Development Mode
# - true: Enables CV template selection, preview, and all themes
# - false: Production mode with streamlined experience (default)
# Set to true during development, false for production
DEV_MODE=false

# Theme Switching in Production
# - true: Users can switch between all 5 themes
# - false: Uses default Magenta Pink theme only (recommended for simplicity)
# Only applies when DEV_MODE=false
SWITCH_THEME=false

# ============================================
# OPTIONAL: CONTACT FORM (Google Sheets)
# ============================================

# Uncomment and configure if you want a working contact form
# Follow Google Sheets API setup guide: https://github.com/charlyautomatiza/devfolio#contact-form
# NEXT_PUBLIC_GOOGLE_SHEETS_ENABLED=true
# GOOGLE_PRIVATE_KEY=your-service-account-private-key
# GOOGLE_CLIENT_EMAIL=your-service-account-email@project.iam.gserviceaccount.com
# GOOGLE_SHEET_ID=your-google-sheet-id

# ============================================
# CUSTOMIZATION GUIDE
# ============================================

# For all other customizations (name, content, text, SEO, etc.):
# → Edit the Markdown files in src/content/
#
# - personal-info.md  → Your name, role, location
# - cv.md            → Experience, education, skills
# - projects.md       → Portfolio projects
# - social-links.md   → LinkedIn, GitHub, email
# - site-config.md    → Site title, SEO, analytics, footer
# - ui-text.md        → All button text and labels
# - feature-flags.md  → Default CV template
#
# NO CODE EDITING REQUIRED! 🎉
